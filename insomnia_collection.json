      "headers": [
        {
          "name": "Content-Type",
          "value": "application/json"
        }
      ],
      "body": {
        "mimeType": "application/json",
        "text": "{\n  \"ownerId\": \"user-001\",\n  \"accountDigit\": \"1\",\n  \"agencyId\": \"agency-001\",\n  \"balance\": 1000.00,\n  \"overdraftLimit\": 500.00,\n  \"transferLimit\": 2000.00,\n  \"accountType\": \"PERSONAL\"\n}"
      }
    },
    {
      "_id": "req_list_accounts",
      "_type": "request",
      "parentId": "fld_accounts",
      "name": "List Accounts",
      "method": "GET",
      "url": "{{ _.base_url }}/api/accounts",
      "parameters": [
        {
          "name": "accountNumber",
          "value": "",
          "disabled": true
        },
        {
          "name": "accountType",
          "value": "PERSONAL",
          "disabled": true
        },
        {
          "name": "accountStatus",
          "value": "ACTIVE",
          "disabled": true
        },
        {
          "name": "page",
          "value": "0",
          "disabled": true
        },
        {
          "name": "size",
          "value": "20",
          "disabled": true
        },
        {
          "name": "sort",
          "value": "createdAt,desc",
          "disabled": true
        }
      ]
    },
    {
      "_id": "req_find_account_by_id",
