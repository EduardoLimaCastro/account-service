      "url": "{{ _.base_url }}/api/accounts/{{ _.account_id }}",
      "headers": [
        {
          "name": "Content-Type",
          "value": "application/json"
        }
      ],
      "body": {
        "mimeType": "application/json",
        "text": "{\n  \"ownerId\": \"user-001\",\n  \"accountNumber\": \"123456789\",\n  \"accountDigit\": \"1\",\n  \"agencyId\": \"agency-001\",\n  \"status\": \"ACTIVE\",\n  \"balance\": 1500.00,\n  \"overdraftLimit\": 500.00,\n  \"transferLimit\": 3000.00,\n  \"accountType\": \"PERSONAL\",\n  \"fraudBlocked\": false\n}"
      }
    },
    {
      "_id": "req_delete_account",
      "_type": "request",
      "parentId": "fld_accounts",
      "name": "Delete Account",
      "method": "DELETE",
      "url": "{{ _.base_url }}/api/accounts/{{ _.account_id }}"
    },
    {
